# Android/Gradle build output. Exception: android/car-monitor-debug.apk is
# intentionally tracked (see DESIGN.md section 11, "Pre-built APK") — don't
# add a blanket *.apk rule here without carving that path back out.
android/build/
android/app/build/
android/.gradle/
android/local.properties
android/app/libs/*
!android/app/libs/.gitkeep
android/.idea/
android/*.iml
android/app/*.iml
android/captures/
