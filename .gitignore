# Android/Gradle build output. Debug APKs are published to GitHub Releases
# by .github/workflows/release-apk.yml (see DESIGN.md section 11, "Pre-built
# APK"), not committed — this covers both the standard build dir and a
# locally built copy at the repo root.
android/build/
android/app/build/
android/.gradle/
android/local.properties
android/app/libs/*
!android/app/libs/.gitkeep
android/.idea/
android/*.iml
android/app/*.iml
android/captures/
android/*.apk
