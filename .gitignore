# Android/Gradle build output. Debug APKs are published to GitHub Releases
# by .github/workflows/release-apk.yml (see DESIGN.md section 11, "Pre-built
# APK"), not committed — this covers both the standard build dir and a
# locally built copy at the repo root.
android/build/
android/app/build/
android/.gradle/
android/local.properties
android/app/libs/*
!android/app/libs/.gitkeep
android/.idea/
android/*.iml
android/app/*.iml
android/captures/
android/*.apk

# Release signing key material must never be committed — it's a GitHub
# Actions secret (see .github/workflows/release-apk.yml), decoded to a
# runner-temp path at build time, not stored in the repo.
*.keystore
*.jks

# Python bytecode cache from running scripts/*.py locally.
__pycache__/
*.pyc

# go test -coverprofile output, generated locally when checking coverage
# (githooks/pre-commit runs this to a temp path, not go/coverage.out — a
# prior commit accidentally committed these from a manual run).
go/coverage.out
go/coverage.html
