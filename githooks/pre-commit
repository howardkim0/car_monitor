#!/usr/bin/env bash
# Runs before every commit: vets, tests, and builds the Go module (the
# actual "app" logic per DESIGN.md) so broken code never lands.
#
# Installed via `git config core.hooksPath githooks`, which
# scripts/setup_ubuntu.sh does automatically. Full Android/APK compilation
# (gomobile bind + gradlew) needs the Android SDK/NDK and is deliberately
# not part of this hook — see DESIGN.md section 11 and CLAUDE.md.
set -euo pipefail

# Statement-coverage floor for `go test -cover ./...`, enforced below.
# 100: every branch in go/ is small, pure business logic with no framework
# I/O to mock, so there's no legitimate gap to leave headroom for — see
# CLAUDE.md's "Coverage is enforced, not just measured" section.
MIN_COVERAGE=100

repo_root="$(git rev-parse --show-toplevel)"
cd "${repo_root}/go"

echo "[pre-commit] gofmt check"
unformatted="$(gofmt -l .)"
if [ -n "${unformatted}" ]; then
  echo "Not gofmt'd:" >&2
  echo "${unformatted}" >&2
  exit 1
fi

echo "[pre-commit] go vet ./..."
go vet ./...

echo "[pre-commit] go test ./... (coverage gate: ${MIN_COVERAGE}%)"
coverage_file="$(mktemp)"
trap 'rm -f "${coverage_file}"' EXIT
go test -coverprofile="${coverage_file}" ./...
total="$(go tool cover -func="${coverage_file}" | tail -1 | awk '{print $NF}' | tr -d '%')"
awk -v total="${total}" -v min="${MIN_COVERAGE}" 'BEGIN {
  if (total + 0 < min + 0) {
    printf "Total statement coverage %.1f%% is below the required %d%% minimum\n", total, min > "/dev/stderr"
    exit 1
  }
  printf "Total statement coverage: %.1f%% (minimum %d%%)\n", total, min
}'

echo "[pre-commit] go build ./... (app compilation)"
go build ./...
